# Copy to .env and fill in real values before deploying.

# --- Edge / TLS (Caddy) ---
# The single hostname Caddy will obtain a Let's Encrypt certificate for. Its A/AAAA
# record must point at this server and ports 80+443 must be reachable from the internet.
# Must match CSRF_TRUSTED_ORIGINS / CORS_ALLOWED_ORIGINS / FRONTEND_URL below.
DOMAIN=yourdomain.com

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Your domain(s) and/or server IP, comma-separated:
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Full origins for admin login / CSRF (must include scheme):
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
# Set True once HTTPS/TLS is terminated at your proxy (Caddy, nginx, Cloudflare, etc.):
SECURE_SSL_REDIRECT=True
# Public site URL used for Stripe success/cancel redirects:
FRONTEND_URL=https://yourdomain.com

# --- Postgres ---
POSTGRES_DB=lilymade
POSTGRES_USER=lilymade
POSTGRES_PASSWORD=change-me-strong-password

# --- Stripe (live or test keys) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
