# Copy to .env and fill in real values before deploying.

# --- Edge / TLS (Caddy) ---
# The single hostname Caddy will obtain a Let's Encrypt certificate for. Its A/AAAA
# record must point at this server and ports 80+443 must be reachable from the internet.
# Must match CSRF_TRUSTED_ORIGINS / CORS_ALLOWED_ORIGINS / FRONTEND_URL below.
DOMAIN=yourdomain.com

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Your domain(s) and/or server IP, comma-separated:
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Full origins for admin login / CSRF (must include scheme):
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
# Set True once HTTPS/TLS is terminated at your proxy (Caddy, nginx, Cloudflare, etc.):
SECURE_SSL_REDIRECT=True
# Public site URL used for Stripe success/cancel redirects:
FRONTEND_URL=https://yourdomain.com

# --- Postgres ---
POSTGRES_DB=lilymade
POSTGRES_USER=lilymade
POSTGRES_PASSWORD=change-me-strong-password

# --- Stripe (live or test keys) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret. Register the endpoint https://yourdomain.com/api/webhooks/stripe/
# in the Stripe Dashboard and subscribe to: checkout.session.completed,
# checkout.session.expired, charge.refunded, charge.dispute.created.
STRIPE_WEBHOOK_SECRET=
# Let Stripe compute VAT/sales tax at checkout. Leave False for VAT-exempt regimes
# (e.g. Italian regime forfettario). If True, set up tax registrations in Stripe.
STRIPE_AUTOMATIC_TAX=False
# Minutes a checkout holds reserved stock before Stripe expires it (30–1440).
CHECKOUT_SESSION_TTL_MINUTES=30

# --- Email (order confirmations, password resets, seller alerts) ---
# Use a transactional provider (Brevo, Resend, Postmark, Mailgun) and set SPF/DKIM
# on your domain. Leave blank in dev to print emails to the container log.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Lilymade <no-reply@yourdomain.com>
# Where new-order and dispute alerts are sent (the seller inbox). Blank disables them.
ORDER_NOTIFICATION_EMAIL=you@yourdomain.com

# --- Monitoring (optional) ---
# Sentry DSN for backend error tracking. Leave blank to disable.
SENTRY_DSN=

# --- Frontend analytics (optional, build-time) ---
# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX). Loaded only after the
# visitor accepts analytics cookies. Leave blank to disable.
VITE_GA_ID=
